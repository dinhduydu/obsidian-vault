		{"id":"f1614e553a4985cf","type":"text","text":"Lực　「力」","x":-380,"y":-40,"width":250,"height":60},
		{"id":"28a5a64811a0b967","type":"text","text":"勢　「Thế」：","x":180,"y":219,"width":250,"height":60},

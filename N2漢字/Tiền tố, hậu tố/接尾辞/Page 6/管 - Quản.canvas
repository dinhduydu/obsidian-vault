{
	"nodes":[
		{"id":"884fd510fbaa600d","type":"file","file":"N2漢字/Tiền tố, hậu tố/接頭辞/Page 4/管 - Quản.canvas","x":388,"y":1832,"width":400,"height":400},
		{"id":"center","type":"text","text":"# ～管（かん）\n\n📚 Hán Việt: QUẢN（管）\n\n🧪 Ý nghĩa trung tâm:\n👉 ống • đường ống • ống dẫn • cấu trúc dạng ống\n\n📌 Sắc thái:\n- dùng trong y học, sinh học, kỹ thuật\n- chỉ vật thể dạng ống hoặc hệ thống dẫn\n- mang tính kỹ thuật / khoa học","x":980,"y":620,"width":940,"height":560},
		{"id":"meaning","type":"text","text":"# Ý nghĩa\n\n🧠 管 = ống / đường dẫn\n\n➡️ Dùng để chỉ:\n- ống dẫn nước, khí, chất lỏng\n- cấu trúc dạng ống trong cơ thể\n- thiết bị ống trong khoa học\n\n📌 Gần nghĩa:\n- tube\n- pipe\n- duct","x":120,"y":520,"width":780,"height":920},
		{"id":"word1","type":"text","text":"# 試験管（しけんかん）\n\n🧪 Ống nghiệm\n\n📚 Hán Việt:\n- 試験 = thử nghiệm\n- 管 = ống\n\n💡 Nghĩa:\n- ống dùng trong phòng thí nghiệm","x":1940,"y":200,"width":980,"height":760},
		{"id":"word2","type":"text","text":"# 消化管（しょうかかん）\n\n🍽️ Đường tiêu hoá\n\n📚 Hán Việt:\n- 消化 = tiêu hoá\n- 管 = ống\n\n💡 Nghĩa:\n- hệ thống ống tiêu hóa trong cơ thể","x":1940,"y":980,"width":980,"height":760},
		{"id":"word3","type":"text","text":"# 真空管（しんくうかん）\n\n📡 Đèn điện tử chân không\n\n📚 Hán Việt:\n- 真空 = chân không\n- 管 = ống\n\n💡 Nghĩa:\n- linh kiện điện tử dạng ống","x":1940,"y":1760,"width":980,"height":760},
		{"id":"word4","type":"text","text":"# 水道管（すいどうかん）\n\n🚰 Ống nước\n\n📚 Hán Việt:\n- 水道 = cấp nước\n- 管 = ống\n\n💡 Nghĩa:\n- ống dẫn nước sinh hoạt","x":1940,"y":2540,"width":980,"height":760},
		{"id":"word5","type":"text","text":"# 毛細管（もうさいかん）\n\n🩸 Mao quản\n\n📚 Hán Việt:\n- 毛細 = mao (tí hon)\n- 管 = ống\n\n💡 Nghĩa:\n- mạch máu cực nhỏ trong cơ thể","x":1940,"y":3320,"width":980,"height":760},
		{"id":"memory","type":"text","text":"# Memory Hint\n\n🧠 Nhớ 管 = “ống dẫn mọi thứ chạy bên trong” 🔧💧\n\n➡️ Hình ảnh:\n- đường ống nước\n- mạch máu trong cơ thể\n- hệ thống dẫn khí\n\n📌 Keyword:\n管 = PIPE / TUBE / DUCT","x":980,"y":2700,"width":1200,"height":860},
		{"id":"pattern","type":"text","text":"# Pattern N3–N1\n\n🧩 [Hệ thống / chức năng] + 管\n→ nghĩa: hệ thống ống dẫn hoặc cấu trúc dạng ống\n\nVí dụ:\n- 気管 = khí quản\n- 血管 = mạch máu\n- 配管 = hệ thống ống dẫn\n\n📌 Dùng trong:\n- y học\n- sinh học\n- kỹ thuật\n- cơ sở hạ tầng","x":1170,"y":20,"width":560,"height":440}
	],

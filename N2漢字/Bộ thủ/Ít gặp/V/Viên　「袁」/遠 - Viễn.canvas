		{"id":"1ab5217dfd5d7e4e","type":"text","text":"Thường dùng cho hoạt động trường học:\n\nhọc sinh đi công viên\nsở thú\nbảo tàng\nleo núi nhẹ","x":383,"y":-79,"width":250,"height":206},
		{"id":"0610e41c727e7268","type":"text","text":"明日は遠足です。\n（あした は えんそく です。）\nNgày mai là buổi dã ngoại.","x":863,"y":-235,"width":280,"height":127},

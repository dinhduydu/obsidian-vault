		{"id":"57b0213eff4f3741","type":"text","text":"財産　「ざいさん」：","x":906,"y":188,"width":250,"height":60},
		{"id":"478755c84a3347f4","type":"file","file":"N2漢字/Bộ thủ/Hay gặp/T/Tài　「才」/Tài　「才」.canvas","x":220,"y":218,"width":173,"height":119},
		{"id":"7cb81e09bda2f645","type":"text","text":"自負　「じふ」：tự hào","x":-2064,"y":500,"width":250,"height":60},
		{"id":"fa2f1c9ab84d8b88","type":"text","text":"私は、読書の量なら友達の誰にも**負け**ないと**自負**している。","x":-1680,"y":420,"width":526,"height":53},
		{"id":"413dc0fb0b4b2a1f","type":"text","text":"貯金　「ちょきん」： tiết kiệm tiền","x":-1216,"y":-1031,"width":250,"height":60},

		{"id":"9cbcc7d5c354a7b7","type":"file","file":"N2漢字/Bộ thủ/Ít gặp/H/Hạt　「曷」.canvas","x":100,"y":1920,"width":124,"height":84},
		{"id":"be3e215a24c59f04","type":"text","text":"- Treo lên\n- Đăng lên\n- Công bố","x":627,"y":1882,"width":253,"height":122},
		{"id":"ce51605bfc8defd6","type":"text","text":"- 掲載（**けい**さい）: đăng tải\n- 掲示（**けい**じ）: niêm yết, thông báo","x":627,"y":1692,"width":404,"height":78}

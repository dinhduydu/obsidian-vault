		{"id":"5e9496d0862d0374","type":"text","text":"Tùy ngữ cảnh có thể:\n\n- tích cực: thoải mái, không stress\n- tiêu cực: quá vô tư, thiếu cảnh giác","x":1081,"y":202,"width":339,"height":158},

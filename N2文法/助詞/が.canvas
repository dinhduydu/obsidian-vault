		{"id":"37b9b24cf0c44508","type":"text","text":"Used when describing specific things with adjectives","x":314,"y":303,"width":250,"height":89},
		{"id":"6a216233b90afff5","type":"text","text":"Marks objects of potential-form verbs (can/able to)","x":314,"y":540,"width":250,"height":60},
		{"id":"7295be533cca3cf2","type":"text","text":"Used as an conjunction (between phrases): but or even through","x":-164,"y":677,"width":250,"height":60},

		{"id":"f904b85976f06edb","type":"text","text":"Dùng khi nói ý so sánh với thứ khác","x":-1009,"y":2090,"width":250,"height":60},
		{"id":"4bb6d53d7046f352","type":"text","text":"Nに比べて","x":-651,"y":1977,"width":250,"height":60},
		{"id":"94781edf8ce02ed3","type":"text","text":"この町のお年寄りは若者に比べて元気で活動的だ。","x":-318,"y":1869,"width":250,"height":60},
		{"id":"1681c57730c608df","type":"text","text":"～ついでに","x":-1691,"y":2493,"width":250,"height":60},

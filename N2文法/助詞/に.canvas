		{"id":"09614a794fc68882","type":"text","text":"Tiếp tục làm một việc gì đó hay một trạng thái sẽ được tiếp tục trong khoảng thời gian mà trạng thái hay hành động đó đang tiếp diễn","x":5322,"y":-7540,"width":250,"height":162},
		{"id":"157a887da890b40b","type":"text","text":"Làm một việc gì hay một việc gì đó xảy ra trong khoảng thời gian mà trạng thái hay hành động đó đang tiếp diễn","x":5282,"y":-7168,"width":250,"height":134},
		{"id":"d42a7d2fc8a82ec8","type":"text","text":"ために","x":4200,"y":-8782,"width":250,"height":60},
		{"id":"2622a84327f04b7a","type":"text","text":"Nによると","x":780,"y":-743,"width":250,"height":60},
		{"id":"905c0faafcc622d3","type":"text","text":"天気予報によると、明日台風が関西に近づくらしい。","x":778,"y":-456,"width":442,"height":69},
		{"id":"c5136212c5e94e56","type":"text","text":"Cho biết nguồn tin trong câu kể lại đều nghe được","x":805,"y":-591,"width":250,"height":60},

		{"id":"608f64aad6f6113d","type":"text","text":"Nhân cơ hội làm A thì thực hiện B luôn","x":-909,"y":2408,"width":250,"height":60},
		{"id":"7fb386a2ca5ab196","type":"text","text":"妹：「ちょっと散歩してくるよ。\n姉：「ついでにcombiniでアイスをかってきて。」","x":-558,"y":2380,"width":378,"height":58},

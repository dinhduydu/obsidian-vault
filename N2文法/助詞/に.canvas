		{"id":"5334c70d602e8336","type":"text","text":"Nếu suy nghĩ từ vị trí A thì B","x":-5927,"y":2358,"width":250,"height":60},
		{"id":"2fc734c55f7045de","type":"text","text":"私にとっての幸せは、　家族が健康でいることだ。","x":-5594,"y":2214,"width":250,"height":60},

		{"id":"e02d14d7d4022296","type":"text","text":"のに","x":2822,"y":-7500,"width":250,"height":60},
		{"id":"c9d9f5cd36eb5a40","type":"file","file":"Pasted image 20260409005041.png","x":-1416,"y":-1600,"width":716,"height":391},
		{"id":"2b658f754268e6c4","type":"text","text":"に決まっている","x":-3522,"y":-67,"width":250,"height":60},
		{"id":"9ee3aab8cf698d88","type":"text","text":"Thể hiện sự suy đoán chắc chắn rằng, bảo đảm, nhất định là","x":-4002,"y":-189,"width":250,"height":89},
		{"id":"c962fe84d9af3683","type":"text","text":"あの作家の漫画なら、おもしろいにきまっている。","x":-3962,"y":13,"width":250,"height":60},
		{"id":"52fd98569dafb3c6","type":"text","text":"において・における","x":-2845,"y":2440,"width":250,"height":60},
		{"id":"26c41b7fa7f11dee","type":"text","text":"「N3」に","x":-1672,"y":1697,"width":250,"height":60},
		{"id":"2a2d658476b0b153","type":"text","text":"において","x":-3117,"y":2587,"width":250,"height":60},
		{"id":"106f0eeaff197a91","type":"text","text":"Nにおいて","x":-3365,"y":2752,"width":250,"height":60},
		{"id":"a178998041bc576d","type":"text","text":"～におけるN","x":-2628,"y":2620,"width":250,"height":60},
		{"id":"f01492d37b661482","type":"text","text":"Dùng khi cho biết địa điểm, tình huống, hoàn cảnh, thời đại","x":-2283,"y":2386,"width":250,"height":60},
		{"id":"75f8c2caaa97a3ba","type":"text","text":"卒業式は大ホールにおいて行われる。","x":-3044,"y":2920,"width":449,"height":60},
		{"id":"c94342e1ecf57004","type":"text","text":"江戸時代における食生活について研究する。","x":-2576,"y":2806,"width":376,"height":60},
		{"id":"2efaeea61b5644ee","type":"file","file":"Pasted image 20260412204611.png","x":-320,"y":-327,"width":392,"height":195},
		{"id":"da3a26aca4c1b496","type":"text","text":"に対して","x":820,"y":-1520,"width":220,"height":60},
		{"id":"56e1afffcf0b1c03","type":"text","text":"Dùng biểu thị sự tác động hay thái độ hướng đến A","x":1201,"y":-1713,"width":250,"height":60},
		{"id":"880a639081c5be31","type":"text","text":"A thường là người/ý kiến/vấn đề/yêu cầu","x":1696,"y":-1834,"width":250,"height":60},
		{"id":"1d0426a4668d7efe","type":"text","text":"Nに対して","x":2088,"y":-1891,"width":250,"height":60},
		{"id":"b2c1ab2b348cfb50","type":"text","text":"～に対するN","x":2093,"y":-1772,"width":250,"height":60},
		{"id":"768984b6cef71548","type":"text","text":"これは、子供の疑問に対する答えを集めた本だ。","x":2560,"y":-1772,"width":250,"height":60},
		{"id":"209b322829915bc5","type":"text","text":"田村先生は学生に対していつも優しい。","x":2571,"y":-1911,"width":389,"height":60},
		{"id":"f2cd76fff7bd2f57","type":"file","file":"Pasted image 20260412205359.png","x":4030,"y":-1622,"width":773,"height":435},

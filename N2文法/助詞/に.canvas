		{"id":"c5136212c5e94e56","type":"text","text":"Cho biết nguồn tin trong câu kể lại đều nghe được","x":1007,"y":-1545,"width":250,"height":60},
		{"id":"905c0faafcc622d3","type":"text","text":"天気予報によると、明日台風が関西に近づくらしい。","x":980,"y":-1410,"width":442,"height":69},
		{"id":"8405b8a943840cd7","type":"text","text":"Lấy A làm phương thức","x":2140,"y":-2320,"width":250,"height":60},

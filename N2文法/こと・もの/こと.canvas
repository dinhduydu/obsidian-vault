		{"id":"1db8d5985e5d4aaf","type":"file","file":"Pasted image 20260412131724.png","x":2380,"y":-750,"width":399,"height":232},
		{"id":"df6f4e7ccd1f8566","type":"text","text":"Dùng khi tránh khẳng định","x":2959,"y":-333,"width":250,"height":60},
		{"id":"a8269325f2ad8f4a","type":"text","text":"Ý chỉ nói cũng có khả năng A","x":2971,"y":-183,"width":269,"height":60},
		{"id":"020d28f408add3f5","type":"text","text":"Không thể nói là tuyệt đối không","x":2988,"y":-56,"width":250,"height":60},
		{"id":"66363cedf23551b1","type":"text","text":"カラオケはあまり得意ではありませんが、行かないこともありません。","x":3360,"y":-363,"width":340,"height":60},
		{"id":"51e092409c028b51","type":"text","text":"妻：「忙しくなかったら手伝って。\n夫：「いそがしくないことはないけど、てつだうよ。」","x":3381,"y":-201,"width":439,"height":50},
		{"id":"fa59a8d24efb50d6","type":"text","text":"ことになっている","x":-3235,"y":-75,"width":250,"height":60},
		{"id":"79204e9c59e1d341","type":"text","text":"Dùng khi đề cập đến 1 quyết định như kế hoạch, quy tắc trong cuộc sống hàng ngày, pháp luật","x":-3638,"y":-161,"width":250,"height":77},
		{"id":"89a85daf0692ccd9","type":"text","text":"trình bày lý do hay nguyên cớ của câu theo sau","x":1637,"y":542,"width":250,"height":60},
		{"id":"e4b2024aa6c0deca","type":"text","text":"ことにしている","x":-3175,"y":-305,"width":250,"height":60},
		{"id":"e9e6dd64f956a8e6","type":"text","text":"Dùng khi nói rằng vẫn duy trì thói quen hay quy tắc cũ mà mình đã đặt ra","x":-3580,"y":-360,"width":250,"height":85},

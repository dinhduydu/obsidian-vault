		{"id":"10133990321f5dab","type":"text","text":"Truyền đạt quan niệm, nhận xét hay lời khuyên của người nói","x":1760,"y":-2195,"width":250,"height":91},
		{"id":"3f1c4e5ba7e1395a","type":"text","text":"ということ","x":640,"y":-1758,"width":250,"height":60},

		{"id":"89a85daf0692ccd9","type":"text","text":"trình bày lý do hay nguyên cớ của câu theo sau","x":1734,"y":-2860,"width":250,"height":62},
		{"id":"c2b547846eb61184","type":"text","text":"Dùng khi nói ko cần làm","x":2884,"y":-810,"width":250,"height":60},
		{"id":"114a72a3a3497e98","type":"file","file":"N2文法/ない・いう・しまう/いう.canvas","x":1556,"y":-1836,"width":255,"height":216},
		{"id":"b17f320e8b2c75a8","type":"text","text":"ことだから","x":1265,"y":-2645,"width":250,"height":60},
		{"id":"2473d6c2f27b1b03","type":"text","text":"Dùng khi muốn truyền đạt điều mình suy nghĩ, phán đoán từ tính cách hay hành động thường ngày của người đang được nhắc đến","x":1734,"y":-2680,"width":324,"height":131},
		{"id":"e91a81b66188b961","type":"text","text":"ことだ","x":1158,"y":-2180,"width":250,"height":60},
		{"id":"8e95a2289c00601c","type":"file","file":"Pasted image 20260412211810.png","x":2868,"y":216,"width":399,"height":219},
		{"id":"df0501785792d288","type":"text","text":"ということだ","x":2199,"y":-1753,"width":250,"height":50},
		{"id":"5e66fce8459e35ce","type":"text","text":"夢を叶えたいなら、一生懸命努力することだ。","x":2340,"y":-2180,"width":250,"height":60},
		{"id":"d326065db2d133dc","type":"file","file":"Pasted image 20260410084839.png","x":2390,"y":-2837,"width":400,"height":217},
		{"id":"fed5cd727e26c3ca","type":"text","text":"まだ時間があるから、諦めることはない。","x":3448,"y":-810,"width":389,"height":60},
		{"id":"df6f4e7ccd1f8566","type":"text","text":"Dùng khi tránh khẳng định","x":3419,"y":-151,"width":250,"height":60},
		{"id":"a8269325f2ad8f4a","type":"text","text":"Ý chỉ nói cũng có khả năng A","x":3431,"y":-1,"width":269,"height":60},
		{"id":"020d28f408add3f5","type":"text","text":"Không thể nói là tuyệt đối không","x":3448,"y":126,"width":250,"height":60},
		{"id":"66363cedf23551b1","type":"text","text":"カラオケはあまり得意ではありませんが、行かないこともありません。","x":3820,"y":-181,"width":340,"height":60},
		{"id":"51e092409c028b51","type":"text","text":"妻：「忙しくなかったら手伝って。\n夫：「いそがしくないことはないけど、てつだうよ。」","x":3841,"y":-19,"width":439,"height":50},
		{"id":"18d7126fbbe8b2a1","type":"text","text":"Truyền đạt ý, quan điểm chung của nhiều người","x":2740,"y":-1769,"width":250,"height":83},

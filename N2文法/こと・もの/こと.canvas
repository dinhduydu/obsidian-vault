		{"id":"10133990321f5dab","type":"text","text":"Truyền đạt quan niệm, nhận xét hay lời khuyên của người nói","x":1624,"y":-1661,"width":250,"height":91},
		{"id":"5e66fce8459e35ce","type":"text","text":"夢を叶えたいなら、一生懸命努力することだ。","x":2063,"y":-1739,"width":250,"height":60},

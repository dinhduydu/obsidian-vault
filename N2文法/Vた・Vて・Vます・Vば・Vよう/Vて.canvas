		{"id":"f68cd52ff6ace246","type":"text","text":"Dùng khi muốn nói nếu không phải là sau khi làm A thì B không thực hiện được","x":2962,"y":-2379,"width":351,"height":84},
		{"id":"75c3672a4779fecb","type":"text","text":"ボタンを押してからでないと、ドアは開かない。","x":3439,"y":-2489,"width":414,"height":60},
		{"id":"6f193e8842db4f65","type":"text","text":"荷物を受け取ってからでなければ、出かけられない。","x":3463,"y":-2322,"width":430,"height":60},

		{"id":"ba59422ef959f2f4","type":"group","x":1940,"y":1700,"width":761,"height":599,"label":"〜というと　ー　Xác nhận lại thông tin/Hễ nói đến"},
		{"id":"3dde684b8ae73939","type":"group","x":3004,"y":-800,"width":498,"height":739,"color":"5","label":"ということ　ー　Việc mà"},
		{"id":"8b95c68cf206d535","type":"file","file":"Chữa đề/Learning_Profile/Grammar/というより.md","x":-2125,"y":304,"width":400,"height":400},
		{"id":"3d96fe60c7d5ed54","type":"file","file":"N2文法/さえ・より/より.canvas","x":-2575,"y":364,"width":262,"height":140},
		{"id":"cbe5649b0dc85aef","type":"text","text":"というより","x":-2563,"y":704,"width":250,"height":60},
		{"id":"18adb54dead3503a","type":"text","text":"Dùng khi muốn nói cách nói A cũng đúng nhưng B thì thích hợp hơn","x":-2947,"y":540,"width":250,"height":82},
		{"id":"1397b9137fdd16da","type":"text","text":"夢を諦めるのは、残念というより悔しい。","x":-3265,"y":434,"width":250,"height":60},
		{"id":"f1be4f9f6a344445","type":"text","text":"という","x":37,"y":691,"width":308,"height":100},
		{"id":"07c514d2b64296fe","type":"file","file":"Pasted image 20260412125807.png","x":-1777,"y":1260,"width":400,"height":198},
		{"id":"f3e81394393cac1d","type":"text","text":"**A というより B**\nđúng hơn là / nói đúng hơn là / không phải A mà là B\n→ sửa lại cách nói cho chính xác hơn","x":-2017,"y":878,"width":480,"height":100},
		{"id":"181394d70055e348","type":"text","text":"Ko phải A mà đúng hơn là B","x":-2980,"y":818,"width":250,"height":60},
		{"id":"48d85e896548497a","type":"file","file":"Pasted image 20260517111943.png","x":-3620,"y":1303,"width":400,"height":155},
		{"id":"7e5c19c0d025ecc5","type":"text","text":"というくらいのN","x":-2563,"y":1617,"width":250,"height":60},
		{"id":"4b627fe4546ecabb","type":"text","text":"というか","x":1287,"y":2821,"width":250,"height":60},
		{"id":"62698673696801bf","type":"text","text":"それは人間としてやむを得ないというか、いわば当たり前の姿と思う。","x":1785,"y":2740,"width":574,"height":50},
		{"id":"8d8ccb933d821f5a","type":"text","text":"Nó có cảm giác:\n\n“hay nói đúng hơn là…”\n\n“phải nói là…”\n\n“nói thế nào nhỉ…”","x":1785,"y":2940,"width":405,"height":168},
		{"id":"a4ba7b808e4a3c15","type":"text","text":"Dùng khi:\n\nsửa/cải chính cách diễn đạt trước đó\nđổi sang cách nói phù hợp hơn\nthêm sắc thái giải thích","x":2350,"y":3013,"width":315,"height":187},
		{"id":"649f856c97fa498f","type":"text","text":"“Điều đó với con người là không thể tránh khỏi, hay nói cách khác, đó vốn là trạng thái tự nhiên bình thường.”","x":2665,"y":2796,"width":568,"height":50},
		{"id":"f926930211ffb9c4","type":"file","file":"Pasted image 20260412130333.png","x":2331,"y":1720,"width":345,"height":181},
		{"id":"29df7584dc35e821","type":"text","text":"はというと","x":3085,"y":1720,"width":250,"height":60},
		{"id":"95c0b7ee6fa646fa","type":"text","text":"というと","x":1960,"y":1786,"width":250,"height":50},
		{"id":"4d8c0405cd84c8be","type":"file","file":"Chữa đề/Learning_Profile/Grammar/〜というと.md","x":2331,"y":2015,"width":350,"height":264},
		{"id":"29c0e621bf0e30fb","type":"file","file":"Chữa đề/Learning_Profile/Grammar/〜かというと.md","x":3151,"y":2097,"width":400,"height":400},
		{"id":"d50a37b04b5067a4","type":"text","text":"Trình bày ý nghĩa, hay định nghĩa của A là B","x":4159,"y":711,"width":250,"height":60},
		{"id":"a85aa5bd16009fb4","type":"file","file":"Pasted image 20260410083626.png","x":2951,"y":1010,"width":400,"height":217},
		{"id":"f8b8e5b0a88c16e9","type":"text","text":"**「強い絆」**の関係というのは、家族や恋人や親友、それに職場の仲間など、ほとんど毎日顔を合わせる人たちだ。","x":3506,"y":430,"width":480,"height":160},
		{"id":"4fe3ce3ad3a928a1","type":"text","text":"ということは","x":3562,"y":-629,"width":250,"height":60},
		{"id":"11247302d06a307f","type":"text","text":"ということだ","x":3562,"y":-399,"width":250,"height":60},
		{"id":"077adeff3c01872b","type":"text","text":"Truyền đạt ý, quan điểm chung của nhiều người","x":4102,"y":-399,"width":250,"height":60},
		{"id":"0a4bc7580704f621","type":"file","file":"N2文法/こと・もの/こと.canvas","x":2834,"y":-369,"width":125,"height":107},

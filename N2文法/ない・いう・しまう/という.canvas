{
	"nodes":[
		{"id":"8ee68b60f9f6db60","type":"group","x":-1794,"y":-2510,"width":2682,"height":1901,"label":"というもの"},
		{"id":"410456751fab1272","type":"group","x":-3296,"y":284,"width":1779,"height":933,"color":"4","label":"A というより B　ー　không phải A mà là B"},
		{"id":"cd9d3b37c72be31b","type":"group","x":1920,"y":1560,"width":1651,"height":957,"label":"というと"},

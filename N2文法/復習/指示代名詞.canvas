		{"id":"4d5f25ca819a86cd","type":"text","text":"Cho biết dù là điều kiện, tình huống, trạng thái nào thì cũng ko ảnh hưởng sự việc phía sau","x":-2984,"y":240,"width":250,"height":120},
		{"id":"82ed534fbc18c47c","type":"text","text":"Diễn tả việc xảy ra trái ngược với việc được cho là đương nhiên và làm việc trái ngược","x":-2313,"y":478,"width":250,"height":122},
